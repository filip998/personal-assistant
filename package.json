{
  "name": "personal-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-platform personal assistant powered by GitHub Copilot SDK",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.8",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.5.0",
    "grammy": "^1.35.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "eslint": "^9.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
