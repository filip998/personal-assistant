# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Comma-separated list of Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=

# Copilot model to use (e.g. claude-sonnet-4, claude-opus-4.6, gpt-4.1, gpt-5.1)
COPILOT_MODEL=claude-sonnet-4

# SQLite database path
DB_PATH=./data/assistant.db

# Log level: debug, info, warn, error
LOG_LEVEL=info
